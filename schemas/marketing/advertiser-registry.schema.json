{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tachyon-ade-bench/marketing/advertiser-registry.schema.json",
  "title": "Marketing Advertiser Registry",
  "type": "object",
  "required": ["schema_version", "updated_at", "advertisers"],
  "properties": {
    "schema_version": { "type": "string" },
    "updated_at": { "type": "string", "format": "date" },
    "advertisers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["product_id", "display_name", "included", "aliases", "notes"],
        "properties": {
          "product_id": { "type": "string" },
          "display_name": { "type": "string" },
          "included": { "type": "boolean" },
          "aliases": {
            "type": "object",
            "required": ["names", "domains", "handles", "github_orgs"],
            "properties": {
              "names": { "type": "array", "items": { "type": "string" } },
              "domains": { "type": "array", "items": { "type": "string" } },
              "handles": { "type": "array", "items": { "type": "string" } },
              "github_orgs": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
