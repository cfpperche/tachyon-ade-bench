{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tachyon-ade-bench/marketing/scan-manifest.schema.json",
  "title": "Marketing Scan Manifest",
  "type": "object",
  "required": ["schema_version", "scan_id", "started_at", "tool_version", "git_commit", "queries", "limitations"],
  "properties": {
    "schema_version": { "type": "string" },
    "scan_id": { "type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z$" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" },
    "tool_version": { "type": "string" },
    "git_commit": { "type": ["string", "null"] },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "product_id", "method", "query", "source_url"],
        "properties": {
          "platform": { "type": "string" },
          "product_id": { "type": "string" },
          "method": {
            "type": "string",
            "enum": ["official-api", "browser-capture", "manual-url", "manual-entry", "export"]
          },
          "query": { "type": "string" },
          "country": { "type": ["string", "null"] },
          "source_url": { "type": "string", "format": "uri" },
          "result": { "type": "string", "enum": ["found", "not-found", "partial", "blocked"] }
        },
        "additionalProperties": false
      }
    },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
