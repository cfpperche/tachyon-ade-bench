{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tachyon-ade-bench/competitor.schema.json",
  "title": "Competitor Profile",
  "type": "object",
  "required": [
    "id",
    "name",
    "class",
    "homepage",
    "source_url",
    "license",
    "runner",
    "inclusion",
    "research",
    "research_status",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "class": {
      "type": "string",
      "enum": [
        "A-local-ade",
        "B-enterprise-agentic-platform"
      ]
    },
    "homepage": { "type": ["string", "null"], "format": "uri" },
    "source_url": { "type": ["string", "null"], "format": "uri" },
    "license": { "type": "string" },
    "runner": {
      "type": "object",
      "required": ["kind", "notes"],
      "properties": {
        "kind": { "type": "string", "enum": ["manual", "cli", "api"] },
        "notes": { "type": "string" }
      }
    },
    "inclusion": { "type": "string" },
    "pricing_model": { "type": "string" },
    "public_stack_signals": { "type": "array", "items": { "type": "string" } },
    "capabilities_to_probe": { "type": "array", "items": { "type": "string" } },
    "moat_hypotheses": { "type": "array", "items": { "type": "string" } },
    "setup_notes": { "type": "array", "items": { "type": "string" } },
    "research": {
      "type": "object",
      "required": [
        "last_reviewed",
        "confidence",
        "sources",
        "positioning",
        "stack",
        "infrastructure",
        "features",
        "benchmarking",
        "moat"
      ],
      "properties": {
        "last_reviewed": { "type": "string", "format": "date" },
        "confidence": {
          "type": "string",
          "enum": [
            "owned",
            "official-sourced",
            "partial-official",
            "seed"
          ]
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["url", "kind", "notes"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "kind": {
                "type": "string",
                "enum": [
                  "official-site",
                  "official-docs",
                  "source-repo",
                  "package-manifest",
                  "app-store",
                  "owned"
                ]
              },
              "notes": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "positioning": { "type": "string" },
        "stack": {
          "type": "object",
          "required": ["runtime", "frontend", "backend", "packaging", "data", "unknowns"],
          "properties": {
            "runtime": { "type": "array", "items": { "type": "string" } },
            "frontend": { "type": "array", "items": { "type": "string" } },
            "backend": { "type": "array", "items": { "type": "string" } },
            "packaging": { "type": "array", "items": { "type": "string" } },
            "data": { "type": "array", "items": { "type": "string" } },
            "unknowns": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "infrastructure": { "type": "array", "items": { "type": "string" } },
        "features": {
          "type": "object",
          "required": [
            "agent_support",
            "orchestration",
            "workspace_isolation",
            "review_shipping",
            "remote_mobile",
            "context_memory",
            "integrations"
          ],
          "properties": {
            "agent_support": { "type": "array", "items": { "type": "string" } },
            "orchestration": { "type": "array", "items": { "type": "string" } },
            "workspace_isolation": { "type": "array", "items": { "type": "string" } },
            "review_shipping": { "type": "array", "items": { "type": "string" } },
            "remote_mobile": { "type": "array", "items": { "type": "string" } },
            "context_memory": { "type": "array", "items": { "type": "string" } },
            "integrations": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "benchmarking": {
          "type": "object",
          "required": ["readiness", "install_surface", "parity_risks", "suggested_first_tasks"],
          "properties": {
            "readiness": {
              "type": "string",
              "enum": [
                "manual-ready",
                "needs-install",
                "enterprise-gated",
                "owned-reference",
                "research-only"
              ]
            },
            "install_surface": { "type": "array", "items": { "type": "string" } },
            "parity_risks": { "type": "array", "items": { "type": "string" } },
            "suggested_first_tasks": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "moat": {
          "type": "object",
          "required": ["hypotheses", "evidence", "unknowns"],
          "properties": {
            "hypotheses": { "type": "array", "items": { "type": "string" } },
            "evidence": { "type": "array", "items": { "type": "string" } },
            "unknowns": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "research_status": { "type": "string" },
    "updated_at": { "type": "string", "format": "date" }
  },
  "additionalProperties": false
}
