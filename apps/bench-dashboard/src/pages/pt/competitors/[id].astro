---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReadinessBadge from "../../../components/ReadinessBadge.astro";
import ConfidenceBadge from "../../../components/ConfidenceBadge.astro";
import { getCompetitors } from "../../../lib/data";
import { classLabel, label } from "../../../lib/format";
import { getUi, type Locale } from "../../../lib/i18n";

export function getStaticPaths() {
  return getCompetitors().map((competitor) => ({
    params: { id: competitor.id },
    props: { competitor },
  }));
}

const { competitor } = Astro.props;
const locale: Locale = "pt";
const t = getUi(locale);
const featureEntries = Object.entries(competitor.research.features);
const stackEntries = Object.entries(competitor.research.stack).filter(([key]) => key !== "unknowns");
const sourceCount = competitor.research.sources.length;
const sourceCountLabel = sourceCount === 1 ? t.common.sourceLink : t.common.trackedSourceLinks;
---

<BaseLayout title={competitor.name} locale={locale} currentPath={`/competitors/${competitor.id}/`}>
  <section class="shell">
    <div class="page-head">
      <div>
        <p class="eyebrow">{classLabel(competitor.class, locale)} {t.competitors.profile}</p>
        <h1>{competitor.name}</h1>
        <p class="lede">{competitor.research.positioning}</p>
        <div class="badge-row">
          <ReadinessBadge value={competitor.research.benchmarking.readiness} locale={locale} />
          <ConfidenceBadge value={competitor.research.confidence} locale={locale} />
          <span class="badge">{competitor.license}</span>
          <span class="badge">{t.common.reviewed} {competitor.research.last_reviewed}</span>
        </div>
      </div>
      <div class="badge-row">
        {competitor.homepage && <a class="badge" href={competitor.homepage}>{t.common.homepage}</a>}
        {competitor.source_url && <a class="badge" href={competitor.source_url}>{t.common.source}</a>}
      </div>
    </div>

    <div class="detail-grid">
      <div>
        <section class="panel">
          <div class="panel__head">
            <div>
              <h2>{t.competitors.stackTitle}</h2>
              <p>{t.competitors.stackDescription}</p>
            </div>
          </div>
          <div class="panel__body split-list">
            {stackEntries.map(([group, values]) => (
              <div>
                <h3>{label(group, locale)}</h3>
                <ul class="text-list">
                  {(values as string[]).map((value) => <li>{value}</li>)}
                </ul>
              </div>
            ))}
            <div>
              <h3>{t.labels.infrastructure}</h3>
              <ul class="text-list">
                {competitor.research.infrastructure.map((value) => <li>{value}</li>)}
              </ul>
            </div>
          </div>
        </section>

        <section class="panel section">
          <div class="panel__head">
            <div>
              <h2>{t.competitors.featureTitle}</h2>
              <p>{t.competitors.featureDescription}</p>
            </div>
          </div>
          <div class="panel__body feature-groups">
            {featureEntries.map(([group, values]) => (
              <div>
                <h3>{label(group, locale)}</h3>
                <ul class="text-list">
                  {(values as string[]).map((value) => <li>{value}</li>)}
                </ul>
              </div>
            ))}
          </div>
        </section>
      </div>

      <aside>
        <section class="panel">
          <div class="panel__head">
            <div>
              <h2>{t.competitors.benchmarkingTitle}</h2>
              <p>{t.competitors.benchmarkingDescription}</p>
            </div>
          </div>
          <div class="panel__body">
            <h3>{t.labels.install_surface}</h3>
            <ul class="text-list">
              {competitor.research.benchmarking.install_surface.map((value) => <li>{value}</li>)}
            </ul>
            <h3 style="margin-top: 16px;">{t.labels.parity_risks}</h3>
            <ul class="text-list">
              {competitor.research.benchmarking.parity_risks.map((value) => <li>{value}</li>)}
            </ul>
            <h3 style="margin-top: 16px;">{t.labels.first_tasks}</h3>
            <div class="badge-row">
              {competitor.research.benchmarking.suggested_first_tasks.map((task) => (
                <span class="badge">{task}</span>
              ))}
            </div>
          </div>
        </section>

        <section class="panel section">
          <div class="panel__head">
            <div>
              <h2>{t.competitors.moatTitle}</h2>
              <p>{t.competitors.moatDescription}</p>
            </div>
          </div>
          <div class="panel__body">
            <h3>{t.labels.hypotheses}</h3>
            <ul class="text-list">
              {competitor.research.moat.hypotheses.map((value) => <li>{value}</li>)}
            </ul>
            <h3 style="margin-top: 16px;">{t.labels.unknowns}</h3>
            <ul class="text-list">
              {competitor.research.moat.unknowns.map((value) => <li>{value}</li>)}
            </ul>
          </div>
        </section>

        <section class="panel section">
          <div class="panel__head">
            <div>
              <h2>{t.common.sources}</h2>
              <p>{sourceCount} {sourceCountLabel}.</p>
            </div>
          </div>
          <div class="panel__body source-list">
            {competitor.research.sources.map((source) => (
              <div class="source-row">
                <a class="link" href={source.url}>{source.kind}</a>
                <small>{source.notes}</small>
              </div>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
