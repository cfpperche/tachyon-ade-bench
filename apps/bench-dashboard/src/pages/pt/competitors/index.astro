---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReadinessBadge from "../../../components/ReadinessBadge.astro";
import ConfidenceBadge from "../../../components/ConfidenceBadge.astro";
import { getCompetitors } from "../../../lib/data";
import { classLabel } from "../../../lib/format";
import { getUi, type Locale } from "../../../lib/i18n";
import { url } from "../../../lib/routes";

const locale: Locale = "pt";
const t = getUi(locale);
const competitors = getCompetitors();
---

<BaseLayout title={t.competitors.title} locale={locale} currentPath="/competitors/">
  <section class="shell">
    <div class="page-head">
      <div>
        <p class="eyebrow">{t.competitors.eyebrow}</p>
        <h1>{t.competitors.h1}</h1>
        <p class="lede">{t.competitors.lede}</p>
      </div>
    </div>

    <div class="list-grid">
      {competitors.map((competitor) => (
        <article class="item-card">
          <div class="badge-row">
            <span class="badge">{classLabel(competitor.class, locale)}</span>
            <ReadinessBadge value={competitor.research.benchmarking.readiness} locale={locale} />
            <ConfidenceBadge value={competitor.research.confidence} locale={locale} />
          </div>
          <h2>{competitor.name}</h2>
          <p>{competitor.research.positioning}</p>
          <div class="item-card__footer">
            <a class="link" href={url(`/competitors/${competitor.id}/`, locale)}>{t.common.openProfile}</a>
            {competitor.homepage && <a class="link" href={competitor.homepage}>{t.common.homepage}</a>}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
