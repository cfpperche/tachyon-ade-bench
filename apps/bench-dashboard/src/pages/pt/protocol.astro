---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProtocolDiagram from "../../components/ProtocolDiagram";
import { getUi, type Locale } from "../../lib/i18n";

const locale: Locale = "pt";
const t = getUi(locale);
---

<BaseLayout title={t.protocol.title} locale={locale} currentPath="/protocol/">
  <section class="shell">
    <div class="page-head">
      <div>
        <p class="eyebrow">{t.protocol.eyebrow}</p>
        <h1>{t.protocol.h1}</h1>
        <p class="lede">{t.protocol.lede}</p>
      </div>
    </div>

    <div class="two-col">
      <section class="panel">
        <div class="panel__head">
          <div>
            <h2>{t.protocol.flowTitle}</h2>
            <p>{t.protocol.flowDescription}</p>
          </div>
        </div>
        <div class="panel__body">
          <ProtocolDiagram client:only="react" labels={t.protocol.diagram} />
        </div>
      </section>

      <section class="panel">
        <div class="panel__head">
          <div>
            <h2>{t.protocol.rulesTitle}</h2>
            <p>{t.protocol.rulesDescription}</p>
          </div>
        </div>
        <div class="panel__body">
          <ol class="text-list">
            {t.protocol.rules.map((rule) => <li>{rule}</li>)}
          </ol>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
