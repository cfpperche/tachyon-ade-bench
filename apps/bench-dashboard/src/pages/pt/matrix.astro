---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CompetitorMatrix from "../../components/CompetitorMatrix";
import { getSummaries } from "../../lib/data";
import { getUi, type Locale } from "../../lib/i18n";

const locale: Locale = "pt";
const t = getUi(locale);
const summaries = getSummaries();
const labels = {
  ...t.matrix,
  product: t.common.product,
  class: t.common.class,
  readiness: t.common.readiness,
  stack: t.common.stack,
  integrations: t.common.integrations,
  evidence: t.common.evidence,
  notMapped: t.common.notMapped,
  source: t.common.source.toLowerCase(),
  sources: t.common.sources.toLowerCase(),
  features: t.common.features,
  classA: t.labels["A-local-ade"],
  classB: t.labels["B-enterprise-agentic-platform"],
  readinessLabels: {
    "manual-ready": t.labels["manual-ready"],
    "needs-install": t.labels["needs-install"],
    "enterprise-gated": t.labels["enterprise-gated"],
    "owned-reference": t.labels["owned-reference"],
    "research-only": t.labels["research-only"],
  },
};
---

<BaseLayout title={t.matrix.title} locale={locale} currentPath="/matrix/">
  <section class="shell">
    <div class="page-head">
      <div>
        <p class="eyebrow">{t.matrix.eyebrow}</p>
        <h1>{t.matrix.h1}</h1>
        <p class="lede">{t.matrix.lede}</p>
      </div>
    </div>
    <CompetitorMatrix client:load competitors={summaries} baseUrl={import.meta.env.BASE_URL} locale={locale} labels={labels} />
  </section>
</BaseLayout>
