---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReadinessBadge from "../../components/ReadinessBadge.astro";
import ConfidenceBadge from "../../components/ConfidenceBadge.astro";
import DashboardCharts from "../../components/DashboardCharts";
import { getCompetitors, getSummaries, getTasks } from "../../lib/data";
import { classLabel } from "../../lib/format";
import { getUi, type Locale } from "../../lib/i18n";
import { url } from "../../lib/routes";

const locale: Locale = "pt";
const t = getUi(locale);
const competitors = getCompetitors();
const summaries = getSummaries();
const tasks = getTasks();
const classACount = competitors.filter((competitor) => competitor.class === "A-local-ade").length;
const sourceCount = competitors.reduce((total, competitor) => total + competitor.research.sources.length, 0);
const manualReady = competitors.filter((competitor) =>
  ["manual-ready", "owned-reference"].includes(competitor.research.benchmarking.readiness),
).length;
const openSourceVisible = competitors.filter(
  (competitor) => competitor.source_url || /mit|agpl|busl|open/i.test(competitor.license),
).length;
const nextRuns = summaries
  .filter((competitor) => competitor.id !== "tachyon")
  .filter((competitor) => ["manual-ready", "needs-install"].includes(competitor.readiness))
  .slice(0, 5);
const chartLabels = {
  ...t.charts,
  readinessLabels: {
    "manual-ready": t.labels["manual-ready"],
    "needs-install": t.labels["needs-install"],
    "enterprise-gated": t.labels["enterprise-gated"],
    "owned-reference": t.labels["owned-reference"],
    "research-only": t.labels["research-only"],
  },
};
---

<BaseLayout title={t.home.title} locale={locale} currentPath="/">
  <section class="shell">
    <div class="page-head">
      <div>
        <p class="eyebrow">{t.home.eyebrow}</p>
        <h1>{t.home.h1}</h1>
        <p class="lede">{t.home.lede}</p>
      </div>
      <a class="badge" href={url("/matrix/", locale)}>{t.home.openMatrix}</a>
    </div>

    <div class="metric-grid" aria-label="Benchmark profile metrics">
      <div class="metric">
        <span>{t.home.metrics.products}</span>
        <strong>{competitors.length}</strong>
        <small>{classACount} {t.home.metrics.productsNote}</small>
      </div>
      <div class="metric">
        <span>{t.home.metrics.tasks}</span>
        <strong>{tasks.length}</strong>
        <small>{t.home.metrics.tasksNote}</small>
      </div>
      <div class="metric">
        <span>{t.home.metrics.sources}</span>
        <strong>{sourceCount}</strong>
        <small>{t.home.metrics.sourcesNote}</small>
      </div>
      <div class="metric">
        <span>{t.home.metrics.runReady}</span>
        <strong>{manualReady}</strong>
        <small>{t.home.metrics.runReadyNote}</small>
      </div>
      <div class="metric">
        <span>{t.home.metrics.sourceVisible}</span>
        <strong>{openSourceVisible}</strong>
        <small>{t.home.metrics.sourceVisibleNote}</small>
      </div>
    </div>

    <div class="section">
      <DashboardCharts client:only="react" competitors={summaries} labels={chartLabels} />
    </div>

    <div class="section two-col">
      <section class="panel">
        <div class="panel__head">
          <div>
            <h2>{t.home.next.title}</h2>
            <p>{t.home.next.description}</p>
          </div>
        </div>
        <div class="panel__body">
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>{t.common.product}</th>
                  <th>{t.common.class}</th>
                  <th>{t.common.readiness}</th>
                  <th>{t.home.next.suggestedTasks}</th>
                </tr>
              </thead>
              <tbody>
                {nextRuns.map((competitor) => (
                  <tr>
                    <td>
                      <a class="link" href={url(`/competitors/${competitor.id}/`, locale)}>
                        {competitor.name}
                      </a>
                    </td>
                    <td>{classLabel(competitor.class, locale)}</td>
                    <td><ReadinessBadge value={competitor.readiness} locale={locale} /></td>
                    <td>{competitor.suggestedTasks.join(", ") || t.common.notMapped}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel__head">
          <div>
            <h2>{t.home.discipline.title}</h2>
            <p>{t.home.discipline.description}</p>
          </div>
        </div>
        <div class="panel__body">
          <div class="badge-row">
            <ConfidenceBadge value="official-sourced" locale={locale} />
            <ConfidenceBadge value="partial-official" locale={locale} />
            <ConfidenceBadge value="owned" locale={locale} />
          </div>
          <ul class="text-list" style="margin-top: 16px;">
            {t.home.discipline.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
