---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCompetitors } from "../../lib/data";
import { getUi, type Locale } from "../../lib/i18n";
import { url } from "../../lib/routes";

const locale: Locale = "pt";
const t = getUi(locale);
const rows = getCompetitors().flatMap((competitor) =>
  competitor.research.sources.map((source) => ({
    product: competitor.name,
    productId: competitor.id,
    ...source,
  })),
);
---

<BaseLayout title={t.sources.title} locale={locale} currentPath="/sources/">
  <section class="shell">
    <div class="page-head">
      <div>
        <p class="eyebrow">{t.sources.eyebrow}</p>
        <h1>{t.sources.h1}</h1>
        <p class="lede">{t.sources.lede}</p>
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>{t.common.product}</th>
            <th>{t.sources.kind}</th>
            <th>{t.common.source}</th>
            <th>{t.sources.supports}</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <td>
                <a class="link" href={url(`/competitors/${row.productId}/`, locale)}>
                  {row.product}
                </a>
              </td>
              <td><span class="badge">{row.kind}</span></td>
              <td><a class="link" href={row.url}>{row.url}</a></td>
              <td>{row.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
