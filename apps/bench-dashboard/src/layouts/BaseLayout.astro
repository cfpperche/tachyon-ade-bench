---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { url } from "../lib/routes";
import { getUi, localeNames, localizedPath, type Locale } from "../lib/i18n";

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  currentPath?: string;
}

const {
  title,
  locale = "en",
  currentPath = "/",
} = Astro.props;
const t = getUi(locale);
const description = Astro.props.description ?? t.metaDescription;
const navItems = [
  [t.nav.overview, "/"],
  [t.nav.matrix, "/matrix/"],
  [t.nav.competitors, "/competitors/"],
  [t.nav.protocol, "/protocol/"],
  [t.nav.sources, "/sources/"],
] as const;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Tachyon ADE Bench</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">{t.skip}</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href={url("/", locale)}>
          <span class="brand__mark">T</span>
          <span>
            <strong>Tachyon ADE Bench</strong>
            <small>{t.brandSubtitle}</small>
          </span>
        </a>
        <nav class="nav" aria-label={t.nav.aria}>
          {navItems.map(([label, href]) => (
            <a href={url(href, locale)}>{label}</a>
          ))}
        </nav>
        <div class="language-switch" aria-label={t.common.language}>
          <a class={locale === "en" ? "is-active" : ""} href={url(localizedPath(currentPath, "en"), "en")}>
            EN
            <span>{localeNames.en}</span>
          </a>
          <a class={locale === "pt" ? "is-active" : ""} href={url(localizedPath(currentPath, "pt"), "en")}>
            PT
            <span>{localeNames.pt}</span>
          </a>
        </div>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
  </body>
</html>
